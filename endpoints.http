@baseUrl = http://localhost:5109

# =============================================================
# INVENTORY — seed products before placing orders
# =============================================================

### Create a product
# @name createProduct
POST {{baseUrl}}/api/inventory/products
Content-Type: application/json

{
  "name": "Widget Pro",
  "sku": "WGT-001",
  "stockQuantity": 100,
  "price": 29.99
}

### Get all products
GET {{baseUrl}}/api/inventory/products
Accept: application/json

# =============================================================
# ORDERS — Choreography (event-driven, no central coordinator)
# =============================================================

### Place order via Choreography (happy path)
# @name choreographyOrder
POST {{baseUrl}}/api/orders/choreography
Content-Type: application/json

{
  "customerId": "customer-001",
  "customerEmail": "alice@example.com",
  "items": [
    {
      "productId": "{{createProduct.response.body.$.value}}",
      "productName": "Widget Pro",
      "quantity": 2,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": false,
  "simulateStockFailure": false
}

### Place order via Choreography — simulate payment failure
POST {{baseUrl}}/api/orders/choreography
Content-Type: application/json

{
  "customerId": "customer-002",
  "customerEmail": "bob@example.com",
  "items": [
    {
      "productId": "00000000-0000-0000-0000-000000000000",
      "productName": "Widget Pro",
      "quantity": 1,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": true,
  "simulateStockFailure": false
}

### Place order via Choreography — simulate stock failure
POST {{baseUrl}}/api/orders/choreography
Content-Type: application/json

{
  "customerId": "customer-003",
  "customerEmail": "carol@example.com",
  "items": [
    {
      "productId": "00000000-0000-0000-0000-000000000000",
      "productName": "Widget Pro",
      "quantity": 1,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": false,
  "simulateStockFailure": true
}

# =============================================================
# ORDERS — Orchestration (Saga state machine)
# =============================================================

### Place order via Orchestration / Saga (happy path)
# @name sagaOrder
POST {{baseUrl}}/api/orders/orchestration
Content-Type: application/json

{
  "customerId": "customer-001",
  "customerEmail": "alice@example.com",
  "items": [
    {
      "productId": "00000000-0000-0000-0000-000000000000",
      "productName": "Widget Pro",
      "quantity": 2,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": false,
  "simulateStockFailure": false
}

### Place order via Orchestration — simulate payment failure (triggers compensation)
POST {{baseUrl}}/api/orders/orchestration
Content-Type: application/json

{
  "customerId": "customer-002",
  "customerEmail": "bob@example.com",
  "items": [
    {
      "productId": "00000000-0000-0000-0000-000000000000",
      "productName": "Widget Pro",
      "quantity": 1,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": true,
  "simulateStockFailure": false
}

### Place order via Orchestration — simulate stock failure
POST {{baseUrl}}/api/orders/orchestration
Content-Type: application/json

{
  "customerId": "customer-003",
  "customerEmail": "carol@example.com",
  "items": [
    {
      "productId": "00000000-0000-0000-0000-000000000000",
      "productName": "Widget Pro",
      "quantity": 1,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": false,
  "simulateStockFailure": true
}

# =============================================================
# ORDERS — Query
# =============================================================

### Get order by ID (replace with actual orderId from above responses)
@orderId = 00000000-0000-0000-0000-000000000000

GET {{baseUrl}}/api/orders/{{orderId}}
Accept: application/json

# =============================================================
# PAYMENTS
# =============================================================

### Get all payments
GET {{baseUrl}}/api/payments
Accept: application/json

# =============================================================
# NOTIFICATIONS
# =============================================================

### Get all notifications
GET {{baseUrl}}/api/notifications
Accept: application/json

@baseUrl = http://localhost:5109

# =============================================================
# INVENTORY — seed products before placing orders
# =============================================================

### Create a product
# @name createProduct
POST {{baseUrl}}/api/inventory/products
Content-Type: application/json

{
  "name": "Widget Pro",
  "sku": "WGT-001",
  "stockQuantity": 100,
  "price": 29.99
}

### Get all products
GET {{baseUrl}}/api/inventory/products
Accept: application/json

# =============================================================
# ORDERS — Orchestration (Saga state machine coordinates steps)
# =============================================================

### Place order (happy path)
# @name placeOrder
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": "customer-001",
  "customerEmail": "alice@example.com",
  "items": [
    {
      "productId": "{{createProduct.response.body.$.id}}",
      "productName": "Widget Pro",
      "quantity": 2,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": false,
  "simulateStockFailure": false
}

### Place order — simulate payment failure (triggers stock compensation)
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": "customer-002",
  "customerEmail": "bob@example.com",
  "items": [
    {
      "productId": "00000000-0000-0000-0000-000000000000",
      "productName": "Widget Pro",
      "quantity": 1,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": true,
  "simulateStockFailure": false
}

### Place order — simulate stock failure
POST {{baseUrl}}/api/orders
Content-Type: application/json

{
  "customerId": "customer-003",
  "customerEmail": "carol@example.com",
  "items": [
    {
      "productId": "00000000-0000-0000-0000-000000000000",
      "productName": "Widget Pro",
      "quantity": 1,
      "unitPrice": 29.99
    }
  ],
  "simulatePaymentFailure": false,
  "simulateStockFailure": true
}

# =============================================================
# ORDERS — Choreography (cancel order, each module reacts independently)
# =============================================================

### Cancel order (publishes OrderCancelledEvent — Inventory, Payments, Notifications react autonomously)
# Replace {orderId} with an actual order ID from a POST /api/orders response
@orderId = 00000000-0000-0000-0000-000000000000

POST {{baseUrl}}/api/orders/{{orderId}}/cancel
Content-Type: application/json

{
  "reason": "Cancelled by customer"
}

# =============================================================
# ORDERS — Query
# =============================================================

### Get order by ID
GET {{baseUrl}}/api/orders/{{orderId}}
Accept: application/json
